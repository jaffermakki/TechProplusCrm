# Copy this file to .env and fill in real values.

# Flask
SECRET_KEY=change-this-to-a-long-random-string
FLASK_ENV=development

# Database
# Local dev default (no setup needed) -> SQLite file in instance/
# DATABASE_URL=sqlite:///techpro.db
#
# Production -> PostgreSQL, e.g.:
# DATABASE_URL=postgresql://neondb_owner:npg_fDUY4CdA3qKv@ep-fragrant-bread-ahifqawb-pooler.c-3.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_URL=sqlite:///techpro.db

# Shop defaults (used to seed Settings on first run)
SHOP_NAME=Tech-Pro+ Repairs
SHOP_PROVINCE=ON
SHOP_CURRENCY=$

# Twilio (optional - leave blank to disable SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Email (optional - leave blank to disable email receipts)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
